            "source": [
                "# 🏷️ ENCODING (KATEGORİK DEĞİŞKEN KODLAMA)\n",
                "> **🎯 AMAÇ:** Kategorik sütunları sayısal forma dönüştürmek  \n",
                "> **📥 GİRDİ:** DataFrame (kategorik sütunlar içeren)  \n",
                "> **📤 ÇIKTI:** Sayısala dönüştürülmüş DataFrame  \n",
                "### 🔧 YÖNTEM SEÇİMİ\n",
                "| Yöntem | Ne zaman? |\n",
                "|--------|-----------|\n",
                "| Label Encoding | Ordinal veya tree-based |\n",
                "| One-Hot Encoding | Nominal, düşuk cardinality |\n",
                "| Target Encoding | Yüksek cardinality + regresyon |\n",
                "### ⚠️ UYARI\n",
                "Encoder'i SADECE train'de fit et!"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "import numpy as np\n",
                "import pandas as pd\n",
                "import matplotlib.pyplot as plt\n",
                "import seaborn as sns\n",
                "from sklearn.preprocessing import LabelEncoder, OrdinalEncoder\n",
                "print('=' * 50 + '\\n🏷️ ENCODING BAŞLATILIYOR\\n' + '=' * 50)\n",
                "cat_cols = df.select_dtypes(include=['object','category']).columns.tolist()\n",
                "print(f'Kategorik sütunlar: {cat_cols}')\n",
                "for col in cat_cols:\n",
                "    print(f'  {col}: {df[col].nunique()} benzersiz')"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "le = LabelEncoder()\n",
                "binary_cols = [c for c in cat_cols if df[c].nunique() == 2]\n",
                "for col in binary_cols:\n",
                "    df[col] = le.fit_transform(df[col])\n",
                "    print(f'  ✅ {col} Label Encoded')\n",
                "\n",
                "ohe_cols = [c for c in cat_cols if c not in binary_cols and df[c].nunique() <= 10]\n",
                "if ohe_cols:\n",
                "    df = pd.get_dummies(df, columns=ohe_cols, drop_first=True, dtype=int)\n",
                "    print(f'  ✅ OHE uygulandi. Yeni shape: {df.shape}')\n",
                "\n",
                "# Ordinal:\n",
                "# enc = OrdinalEncoder(categories=[['Dusuk','Orta','Yuksek']])\n",
                "# df[['col_enc']] = enc.fit_transform(df[['col']])\n",
                "\n",
                "# Target Encoding (train'de hesapla!):\n",
                "# mean = X_train.groupby('sehir')['target'].mean()\n",
                "# X_train['sehir_enc'] = X_train['sehir'].map(mean)\n",
                "# X_test['sehir_enc']  = X_test['sehir'].map(mean)"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "remaining_cat = df.select_dtypes(include=['object','category']).columns.tolist()\n",
                "print(f'Kalan kategorik: {remaining_cat if remaining_cat else "YOK ✅"}')\n",
                "\n",
                "plt.figure(figsize=(12, 8))\n",
                "corr = df.corr(numeric_only=True)\n",
                "mask = np.triu(np.ones_like(corr, dtype=bool))\n",
                "sns.heatmap(corr, mask=mask, annot=True, fmt='.2f', cmap='coolwarm', center=0, linewidths=0.3)\n",
                "plt.title('Korelasyon Matrisi (Encoding Sonrasi)', fontweight='bold')\n",
                "plt.tight_layout(); plt.show()\n",
                "print('\\n✅ İşlem Tamamlandı.')"
            ]
        }
    ],
